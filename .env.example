# ── LLM Configuration ──────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Redis Configuration ────────────────────────────────────────
# For local development: redis://localhost:6379
# For Railway: auto-provided via Redis plugin
REDIS_URL=redis://localhost:6379

# ── Database Configuration ────────────────────────────────────
# For local development (SQLite): sqlite+aiosqlite:///./agentos.db
# For Railway (PostgreSQL): auto-provided via Postgres plugin
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentdb

# ── Application Configuration ──────────────────────────────────
# Railway automatically sets PORT; local dev defaults to 8000
PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# ── Observability (Optional) ───────────────────────────────────
# For local dev with Docker Compose: http://otel-collector:4317
# For Railway: leave empty or use external OTEL collector
OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090
